# AgentHub 环境变量配置
# 复制此文件为 .env 并根据需要修改

# SQLite 数据库路径（默认使用项目根目录下的 dev.db）
DATABASE_URL="file:./dev.db"

# ── E2E 测试凭证（可选） ──────────────────────────────
# 未设置时 tests/e2e-contract.test.ts 自动 skip,不影响 CI
# 启用方法:E2E=1 npx vitest run tests/e2e-contract.test.ts
# MIMO_TEST_API_KEY=tp-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# MIMO_TEST_BASE_URL=https://token-plan-cn.xiaomimimo.com/anthropic
# MIMO_TEST_MODEL=mimo-v2.5-pro[1m]
