generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─── 会话 ────────────────────────────────────────────
// type: orchestrator=主会话, group=群聊, private=私聊
model Session {
  id             String    @id @default(uuid())
  title          String
  type           String    @default("group") // orchestrator | group | private
  phase          String    @default("idle")   // idle | alignment | execution | done
  phaseStep      String    @default("")       // "" | "pm_confirm" | "architect_plan" | "agent_qa"
  projectDir     String    @default("")       // 用户指定的项目目录
  permissionMode String    @default("default") // "default" | "auto"
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  isPinned       Boolean   @default(false)    // 置顶
  isArchived     Boolean   @default(false)    // 归档

  members     SessionMember[]
  tasks       Task[]
  messages    Message[]
  attachments Attachment[]
}

// ─── Agent 全局池 ─────────────────────────────────────
// 全局共享，通过 SessionMember 与 Session 建立多对多关系
model AppConfig {
  key       String   @id
  value     String   @default("")
  updatedAt DateTime @updatedAt
}

// ─── 服务商配置 ────────────────────────────────────────
// 已保存的服务商配置模板，创建 Agent 时选中后复制到 Agent 自身字段
model Provider {
  id        String   @id @default(uuid())
  name      String   @unique          // 如"讯飞代理"、"Anthropic 官方"
  baseUrl   String   @default("")     // API 端点
  apiKey    String   @default("")     // API Key
  model     String   @default("")     // 默认模型
  category  String   @default("custom") // official | cn_official | aggregator | third_party | custom
  createdAt DateTime @default(now())
}

model Agent {
  id           String  @id @default(uuid())
  name         String  @unique            // 中文角色名，如"前端工程师"
  expertise    String                    // 专长描述
  systemPrompt String                    // Agent 行为规范
  platform     String  @default("claude-code")   // claude-code | opencode
  model        String  @default("")      // 模型标识，如 claude-opus-4-7
  baseUrl      String  @default("")      // 服务商 base_url（CC-Switch 导入）
  apiKey       String  @default("")      // 服务商 API Key（加密存储）
  tools        String  @default("[]")    // JSON 数组，工具集标识
  isPreset     Boolean @default(false)   // 预设 vs 用户自建
  isOrchestrator Boolean @default(false)   // Orchestrator 特殊标记
  accentColor  String  @default("#6366f1") // 主题色 hex
  capabilities String  @default("[]")    // JSON 数组，能力标签
  status       String  @default("idle")  // @deprecated: 使用 SessionMember.status 代替（per-session 状态）

  memberships SessionMember[]
  tasks       Task[]
}

// ─── 会话成员中间表 ───────────────────────────────────
model SessionMember {
  id        String   @id @default(uuid())
  sessionId String
  agentId   String
  cliSessionId String?                      // CLI Agent sessionID，用于会话恢复
  joinedAt  DateTime @default(now())
  role      String   @default("member") // member | orchestrator
  status    String   @default("idle")   // idle | working | done | error (per-session)

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  agent   Agent   @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([sessionId, agentId])
}

// ─── 任务 ─────────────────────────────────────────────
// 依赖关系通过 dependencies JSON 数组表达
model Task {
  id              String   @id @default(uuid())
  description     String
  status          String   @default("pending") // pending | in_progress | completed | failed | blocked
  assignedAgentId String?
  sessionId       String
  dependencies    String   @default("[]")      // JSON 数组，依赖的 taskId 列表
  declaredFiles   String   @default("[]")      // JSON 数组，声明修改的文件列表（冲突预防）
  workspacePath   String?                      // CLI Agent 隔离工作区路径
  cliSessionId    String?                      // CLI Agent sessionID，用于会话恢复
  correctionCount Int      @default(0)        // 纠偏重试计数器
  trace           String   @default("[]")     // JSON 数组，执行轨迹
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  assignedAgent Agent?   @relation(fields: [assignedAgentId], references: [id], onDelete: SetNull)
  session       Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  messages      Message[]
}

// ─── 消息 ─────────────────────────────────────────────
// 只存 rawContent，读取时解析为结构化 JSON（决策 #16）
model Message {
  id          String   @id @default(uuid())
  role        String                       // user | agent | orchestrator
  rawContent  String                       // Agent 原始纯文本输出
  agentId     String?
  taskId      String?
  replyToId   String?                      // 回复引用（决策 #15）
  isPinned    Boolean  @default(false)      // Pin 消息作为长期上下文
  sessionId   String
  createdAt   DateTime @default(now())

  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  task        Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  replyTo     Message? @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies     Message[] @relation("MessageReplies")
  attachments Attachment[]
}

// ─── 附件 ─────────────────────────────────────────────
// 用户上传的图片/文件，先上传后关联消息
model Attachment {
  id        String   @id @default(uuid())
  filename  String                     // 原始文件名
  path      String                     // 磁盘路径: uploads/{sessionId}/{uuid}.{ext}
  mimeType  String                     // image/png 等
  size      Int                        // 字节数
  messageId String?                    // 可空，上传时无消息，发消息时关联
  sessionId String                     // 方便查询孤儿文件
  createdAt DateTime @default(now())

  message Message? @relation(fields: [messageId], references: [id], onDelete: Cascade)
  session Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

// ─── 最近打开的目录 ───────────────────────────────────
model RecentDir {
  id        String   @id @default(uuid())
  path      String   @unique          // 目录路径
  lastUsed  DateTime @default(now())  // 最后使用时间
  useCount  Int      @default(1)      // 使用次数
}
